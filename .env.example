# ── Local Authentication (Prestige Build) ──
SESSION_SECRET=your-secure-session-secret-at-least-32-chars

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://user:password@localhost:5432/prestige_build

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── AI Providers (at least one required) ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...

# ── Vercel (for CD pipeline) ──
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID=...

# ── Sentry (optional) ──
NEXT_PUBLIC_SENTRY_DSN=...

# ── Supabase (required for project management) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── GitHub App (optional, for OAuth flow) ──
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ── AI Builder (optional, uses OPENAI_API_KEY above by default) ──
OPENAI_MODEL=gpt-4-turbo

# ── Figma Import (optional) ──
FIGMA_ACCESS_TOKEN=figd_...
FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=

# ── Collaboration (optional) ──
LIVEBLOCKS_SECRET_KEY=sk_...
LIVEBLOCKS_PUBLIC_KEY=pk_...
WEBSOCKET_URL=wss://...
